# ==================== .env Configuration File ====================
# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=4312
DB_NAME=shopping_platform
DB_PORT=3306

# JWT Configuration
JWT_SECRET=8295b3dab43c021b049df411b08a16e9
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ML Service Configuration
ML_SERVICE_URL=http://localhost:5000
ML_SERVICE_ENABLED=true

# Token System Configuration
TOKEN_TO_RUPEE_RATIO=1
DEFAULT_SIGNUP_TOKENS=100
REFERRAL_BONUS_TOKENS=50
FIRST_PURCHASE_BONUS=25

# Email Configuration (Optional - for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@swap.com

# SMS Configuration (Optional - for OTP)
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.sms-provider.com/send

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_TIMEOUT=3600000

# Payment Gateway (Future Integration)
PAYMENT_GATEWAY_KEY=your-payment-gateway-key
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Cache Configuration (if using Redis - Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Admin Configuration
ADMIN_EMAIL=admin@swap.com
ADMIN_INITIAL_PASSWORD=Admin@123